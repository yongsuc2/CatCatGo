{
  "permissions": {
    "allow": [
      "Agent",
      "Bash(dotnet build*)",
      "Bash(dotnet test*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git merge*)",
      "Bash(git checkout*)",
      "Bash(git worktree*)",
      "Bash(git show*)",
      "Bash(git stash*)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(grep *)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-dangerous.sh"
          }
        ]
      }
    ]
  }
}
