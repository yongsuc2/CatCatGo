{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "CatCatGo": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Hosting.Diagnostics": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "TimestampFormat": "HH:mm:ss.fff ",
        "IncludeScopes": true,
        "SingleLine": true
      }
    }
  }
}
